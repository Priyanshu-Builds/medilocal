# Copy to .env for local development
# 127.0.0.1 (not localhost) — Windows can resolve localhost to IPv6 where Docker isn't listening
DATABASE_URL="postgresql://medilocal:medilocal@127.0.0.1:5432/medilocal?schema=public"
REDIS_URL="redis://localhost:6379"
PORT=3000
CORS_ORIGINS=http://localhost:3001,http://localhost:3002

# JWTs issued by our backend after login (change in every real environment)
JWT_SECRET=dev-only-change-me
JWT_REFRESH_SECRET=dev-only-change-me-too

# Firebase Admin service account — needed for customer phone-OTP login (M1).
# Firebase Console > Project Settings > Service Accounts > Generate new private key
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Razorpay (M1) — test keys from dashboard.razorpay.com
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# S3 (M1) — private bucket, ap-south-1 (Mumbai)
S3_REGION=ap-south-1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# S3-compatible endpoint override for local dev (e.g. MinIO http://localhost:9000); leave empty for real AWS S3
S3_ENDPOINT=

# Dev-only: POST /v1/auth/dev/login mints customer/rider JWTs without Firebase.
# Hard-disabled in production regardless of this flag. Never enable on a public server.
DEV_LOGIN_ENABLED=false
