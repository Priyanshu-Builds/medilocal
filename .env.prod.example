# Copy to .env (repo root) for docker-compose.prod.yml — Postgres creds + domain.
# App secrets (JWT/Razorpay/Firebase/S3/Sentry) live in apps/api/.env.production.
POSTGRES_USER=medilocal
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=medilocal

# Public hostname Nginx serves (used in docker/nginx/medilocal.conf via server_name).
DOMAIN=api.example.com
